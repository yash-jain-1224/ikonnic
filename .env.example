# Copy this file to .env.local and fill in values
# Full documentation: infrastructure/docs/04-environment-variables.md

# ─── Core ───────────────────────────────────────────────────────────
# Dev: http://localhost:3000 | Prod: https://ikonnic.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ikonnic
# Backend API — Dev: http://localhost:4000/api/v1 | Prod: https://ikonnic-api.vercel.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── Authentication (Microsoft Entra ID) ────────────────────────────
AZURE_AD_CLIENT_ID=045807c6-f112-4362-b951-ff014feb59f2
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=02b70906-c568-452f-85fd-1fbc1f66f2f6
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── Authentication (Google OAuth) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database (Azure PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ikonnic_dev
# DATABASE_URL=postgresql://ikonnic_admin:IkonnicMvp2026SecureDB01@ikonnic-pg-server.postgres.database.azure.com:5432/ikonnic_db?sslmode=require

# ─── Storage (Azure Blob Storage) ───────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_ACCOUNT_NAME=devstorageaccount
NEXT_PUBLIC_STORAGE_URL=http://127.0.0.1:10000/devstorageaccount

# ─── Email (SendGrid) ───────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ikonnic.com
SENDGRID_FROM_NAME=Ikonnic

# ─── Payment (Razorpay) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# ─── Monitoring (Azure Application Insights) ────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=

# ─── Monitoring (Sentry) ────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Feature Flags ──────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_WISHLIST=true
NEXT_PUBLIC_ENABLE_CUSTOMIZER=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
