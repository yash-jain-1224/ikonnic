# ─────────────────────────────────────────────
# IKONNIC BACKEND - ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://ikonnic:ikonnic_secret@localhost:5432/ikonnic_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# PhonePe
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_CALLBACK_URL=https://your-backend.com/api/v1/payments/webhook/phonepe
PHONEPE_REDIRECT_URL=https://your-frontend.com/checkout

# Stripe (International)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Email (SMTP — Gmail with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ikonnicdecor@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Ikonnic <ikonnicdecor@gmail.com>"

# SMS (Azure Communication Services)
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://ikonnic-comm.communication.azure.com/;accesskey=xxx
AZURE_SMS_SENDER=+1xxxxxxxxxx

# WhatsApp Business API
WHATSAPP_API_KEY=your_whatsapp_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_id

# File Storage (Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=ikonnicstore;AccountKey=xxx;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=ikonnicstore
AZURE_STORAGE_ACCOUNT_KEY=your_account_key
AZURE_STORAGE_CONTAINER=uploads
CDN_URL=https://cdn.ikonnic.com

# Shipping - Shiprocket
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Cron Job Secret (for secured cron endpoints)
CRON_SECRET=your-cron-secret-change-in-production

# Logging
LOG_LEVEL=debug

# Monitoring (Azure Application Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://centralindia-0.in.applicationinsights.azure.com/

# Azure Entra ID (Microsoft SSO — ID token verification)
AZURE_AD_CLIENT_ID=your_azure_ad_application_client_id
AZURE_AD_TENANT_ID=your_azure_ad_tenant_id
